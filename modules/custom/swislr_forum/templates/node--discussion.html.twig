{{ attach_library('swislr_forum/forum-node') }}
{{ attach_library('swislr_comment_spice/ui') }}

{#
  Custom full-page layout for Discussion (forum) nodes.
  Fields: title, body, image, tags, comments.
#}

{% set classes = [
  'node',
  'node--type-discussion',
  view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  'forum-layout'
] %}

<article{{ attributes.addClass(classes) }}>
  <header class="forum-hero">
    <time class="forum-date" datetime="{{ node.getCreatedTime|date('c') }}">
      {{ node.getCreatedTime|date('M d, Y') }}
    </time>

    {% if content.field_image is defined and content.field_image %}
      <div class="forum-image">
        {{ content.field_image }}
      </div>
    {% endif %}
  </header>

  <div class="forum-grid">
    <main class="forum-main">

      {% if content.body is defined and content.body %}
        <div class="forum-body">
          {{ content.body }}
        </div>
      {% endif %}

      {% if content.field_tags is defined and content.field_tags %}
        <div class="forum-tags">
          {{ content.field_tags }}
        </div>
      {% endif %}

    </main>

    <aside class="forum-aside">
      {# Extra widgets/links can go here later. #}
    </aside>
  </div>

  {% if content.field_comment is defined and content.field_comment %}
    <section class="forum-comments">
      {{ content.field_comment }}
    </section>
  {% endif %}

  {% if content.links is defined and content.links %}
    <div class="forum-links">
      {{ content.links }}
    </div>
  {% endif %}
</article>
